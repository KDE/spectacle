#, kde-format
msgid "Cannot save screenshot. Error while writing temporary local file."
msgstr ""
"Kan ikke lagre skjermbildet. Feil ved skriving av midlertidig lokal fil."

#: src/ExportManager.cpp:524
#, kde-format
msgid "Unable to save image. Could not upload file to remote location."
msgstr ""
"Kan ikke lagre bildet. Feil ved opplasting av fila til eksternt område."

#: src/ExportManager.cpp:572
#, kde-format
msgid "Cannot save screenshot. The save filename is invalid."
msgstr "Kan ikke lagre skjermbildet. Filnavnet er ugyldig."

#: src/ExportManager.cpp:616
#, kde-format
msgid "Cannot save an empty screenshot image."
msgstr "Kan ikke lagre et tomt skjermbilde."

#: src/ExportManager.cpp:775
#, kde-format
msgctxt "@info:shell"
msgid ""
"Failed to export video: Temporary file URL must be an existing local file"
msgstr ""
"Klarte ikke å eksportere video: Adressen til midlertidig fil må være en "
"eksisterende lokal fil"

#: src/ExportManager.cpp:782
#, kde-format
msgctxt "@info:shell"
msgid ""
"Failed to export video: Output file URL must be a valid URL with a file name"
msgstr ""
"Klarte ikke å eksportere video: Adressen til utfil må være en gyldig adresse "
"som innholder et filnavn"

