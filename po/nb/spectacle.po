#: src/CommandLineOptions.h:22
#, kde-format
msgid "Capture the entire desktop (default)"
msgstr "Ta bilde av hele skrivebordet (standard)"

#: src/CommandLineOptions.h:26
#, kde-format
msgid ""
"When used with -f/--fullscreen, capture all screens scaled to the same size"
msgstr ""

#: src/CommandLineOptions.h:30
#, kde-format
msgid "Capture the current monitor"
msgstr "Ta bilde av gjeldende skjerm"

#: src/CommandLineOptions.h:34
#, kde-format
msgid "Capture the active window"
msgstr "Ta bilde av aktivt vindu"

#: src/CommandLineOptions.h:38
#, kde-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus"
msgstr ""
"Ta bilde av vinduet under musepekeren, inkludert opphavsvindu for "
"sprettoppmenyer"

#: src/CommandLineOptions.h:42
#, kde-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus"
msgstr ""
"Ta bilde av vinduet under musepekeren, men ikke av opphavsvindu for "
"sprettoppmenyer"

#: src/CommandLineOptions.h:46
#, kde-format
msgid "Capture a rectangular region of the screen"
msgstr "Ta bilde av et utsnitt av skjermbildet"

#: src/CommandLineOptions.h:50
#, kde-format
msgid ""
"Record the screen using the given mode. Modes:\n"
"- r, region\n"
"- s, screen\n"
"- w, window"
msgstr ""
"Gjør opptak av skjermbildet med valgt modus. Tilgjengelige moduser:\n"
"- r, skjermutsnitt\n"
"- s, skjerm\n"
"- w, vindu"

#: src/CommandLineOptions.h:58
#, kde-format
msgid "Launch Spectacle without taking a screenshot"
msgstr "Kjør Spectacle uten å ta skjermbilde"

#: src/CommandLineOptions.h:62
#, kde-format
msgid "Start in GUI mode (default)"
msgstr "Start med grafisk grensesnitt (standard)"

#: src/CommandLineOptions.h:66
#, kde-format
msgid "Take a screenshot and exit without showing the GUI"
msgstr "Ta skjermbildet og avslutt uten å vise det grafiske grensesnittet"

#: src/CommandLineOptions.h:70
#, kde-format
msgid "Start in DBus-Activation mode"
msgstr "Start i DBus-aktiveringsmodus"

#: src/CommandLineOptions.h:74
#, kde-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is taken"
msgstr ""
"I bakgrunnsmodus, ikke vis melding på skjermen når skjermbildet er tatt"

#: src/CommandLineOptions.h:78
#, kde-format
msgid "In background mode, save image to specified file"
msgstr "I bakgrunnsmodus, lagre bildet i spesifisert fil"

#: src/CommandLineOptions.h:83
#, kde-format
msgid "In background mode, delay before taking the shot (in milliseconds)"
msgstr ""
"I bakgrunnsmodus med forsinkelse før skjermbildet blir tatt (i millisekund)"

#: src/CommandLineOptions.h:88
#, kde-format
msgid ""
"In background mode, copy screenshot image to clipboard, unless -o is also "
"used."
msgstr ""
"I bakgrunnsmodus, kopier skjermbildet til utklippstavlen, men mindre «-o» er "
"brukt."

#: src/CommandLineOptions.h:92
#, kde-format
msgid "In background mode, copy screenshot file path to clipboard"
msgstr ""
"I bakgrunnsmodus, kopier filadressen til skjermbildet til utklippstavlen"

#: src/CommandLineOptions.h:96
#, kde-format
msgid "Wait for a click before taking screenshot. Invalidates delay"
msgstr "Vent på klikk før skjermbildet tas. Overstyrer angitt forsinkelse"

#: src/CommandLineOptions.h:100
#, kde-format
msgid "Starts a new GUI instance of spectacle without registering to DBus"
msgstr "Start et nytt Spectacle-vindu uten å registrere med DBus"

#: src/CommandLineOptions.h:104
#, kde-format
msgid "In background mode, include pointer in the screenshot"
msgstr "I bakgrunnsmodus, ikke ta med musepekeren i skjermbildet"

#: src/CommandLineOptions.h:108
#, kde-format
msgid "In background mode, exclude decorations in the screenshot"
msgstr "I bakgrunnsmodus, ikke ta med vinduspynt i skjermbildet"

#: src/CommandLineOptions.h:110
#, kde-format
msgid "In background mode, exclude shadows in the screenshot"
msgstr "I bakgrunnsmodus, ikke ta med skygger i skjermbildet"

#: src/CommandLineOptions.h:113
#, kde-format
msgid "Open and edit existing screenshot file"
msgstr "Åpne og rediger eksisterende skjermbildefil"

#: src/CommandLineOptions.h:116
#, kde-format
msgid "Accept region selection on click-and-release"
msgstr "Godta utsnitt på klikk-og-slipp"

